# Frontend Environment Variables
# Copy to .env and fill in values

# ── Development (leave empty — Vite proxy handles /api → localhost:5000)
VITE_API_URL=

# ── Production (set to your Render backend URL)
# VITE_API_URL=https://pdcompanion-api.onrender.com

# Backend URL for Socket.IO
# Development:
VITE_SOCKET_URL=http://localhost:5000
# Production:
# VITE_SOCKET_URL=https://pdcompanion-api.onrender.com
